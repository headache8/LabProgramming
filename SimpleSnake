#include <SDL.h>
#include <stdio.h>

#define WINDOW_WIDTH 800
#define WINDOW_HEIGHT 600
#define SIZE_SNAKE 5
#define SIZE_RECT_SNAKE 20

#define SPEED_X SIZE_RECT_SNAKE 
#define SPEED_Y SIZE_RECT_SNAKE

void drawSnake(SDL_Renderer* renderer, int snakeX[], int snakeY[])
{
    SDL_SetRenderDrawColor(renderer, 0, 255, 0, 255);
    for (int i = 0; i < SIZE_SNAKE; i++)
    {
        // Рисуем прямоугольник чуть меньше ,чтобы создать визуальный зазор между частями
        int drawSize = SIZE_RECT_SNAKE - 2;
        SDL_Rect rect = { snakeX[i] + 1, snakeY[i] + 1, drawSize, drawSize };
        SDL_RenderFillRect(renderer, &rect);
    }
}

int main(int argc, char* argv[])
{
    if (SDL_Init(SDL_INIT_VIDEO) < 0)
    {
        printf("Error:%s", SDL_GetError());
        return 1;
    }

    SDL_Window* window = SDL_CreateWindow("Snake",
        SDL_WINDOWPOS_CENTERED,
        SDL_WINDOWPOS_CENTERED,
        WINDOW_WIDTH,
        WINDOW_HEIGHT,
        SDL_WINDOW_SHOWN);
    if (!window)
    {
        printf("Error:%s", SDL_GetError());
        return 1;
    }

    SDL_Renderer* renderer = SDL_CreateRenderer(window, -1, SDL_RENDERER_ACCELERATED);
    if (!renderer)
    {
        printf("Error:%s", SDL_GetError());
        return 1;
    }

    int snakeX[SIZE_SNAKE];
    int snakeY[SIZE_SNAKE];

    // начальное положение в ряд
    for (int i = 0; i < SIZE_SNAKE; i++)
    {
        snakeX[i] = 110 - i * SIZE_RECT_SNAKE;
        snakeY[i] = WINDOW_HEIGHT / 2;
    }

    int speedY = SPEED_Y;
    //границы движения
    int top = WINDOW_HEIGHT / 2 - 100;
    int bottom = WINDOW_HEIGHT / 2 + 100;

    SDL_Event e;
    int run = 0;

    while (!run)
    {
        while (SDL_PollEvent(&e))
        {
            if (e.type == SDL_QUIT)
            {
                run = 1;
            }
        }

        SDL_SetRenderDrawColor(renderer, 0, 0, 0, 255);
        SDL_RenderClear(renderer);

        // сдвигаем хвост к голове
        for (int i = SIZE_SNAKE - 1; i > 0; i--)
        {
            snakeX[i] = snakeX[i - 1];
            snakeY[i] = snakeY[i - 1];
        }

        // двигаем голову
        snakeX[0] += SPEED_X;
        snakeY[0] += speedY;

        if (snakeY[0] + SIZE_RECT_SNAKE >= bottom)
        {
            snakeY[0] = bottom - SIZE_RECT_SNAKE;
            speedY = -SPEED_Y;
        }
        if (snakeY[0] <= top)
        {
            snakeY[0] = top;
            speedY = SPEED_Y;
        }

        // сброс за экраном
        if (snakeX[0] > WINDOW_WIDTH)
        {
            for (int i = 0; i < SIZE_SNAKE; i++)
            {
                snakeX[i] = -i * SIZE_RECT_SNAKE;
                snakeY[i] = WINDOW_HEIGHT / 2;
            }
        }

        drawSnake(renderer, snakeX, snakeY);

        SDL_RenderPresent(renderer);
        SDL_Delay(100);
    }

    SDL_DestroyRenderer(renderer);
    SDL_DestroyWindow(window);
    SDL_Quit();

    return 0;
}
